# Copy this file to .env before running docker-compose:
#   cp .env.example .env
#
# Required for auth (monolith). Change in production.
JWT_SECRET=dev-jwt-secret-change-me

# Required for product image uploads (monolith product service).
# Get free credentials at https://cloudinary.com
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional overrides (defaults are set in docker-compose.yml)
# NODE_ENV=development
# LOG_LEVEL=info

# --- Local development without Docker (npm run dev) ---
# MONGO_URI=mongodb://localhost:27017/avenyx
# REDIS_HOST=localhost
# REDIS_PORT=6379
# KAFKA_BROKERS=localhost:9092
# SERVER_PORT=3000
# MONOLITH_URL=http://localhost:3000
